rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Registrations - public can create, only authenticated can read/update/delete
    match /registrations/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }
    
    // News - public can read, only authenticated can write
    match /news/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Gallery - public can read, only authenticated can write
    match /gallery/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Schedule - public can read, only authenticated can write
    match /schedule/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Courses - public can read, only authenticated can write
    match /courses/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Testimonials - public can read, only authenticated can write
    match /testimonials/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Custom Pages - public can read, only authenticated can write
    match /pages/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Settings (for partner banner, etc) - public can read, only authenticated can write
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
